[Unit]
Description=MatriCare FastAPI Backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/high-risk-pregnancy-detection/backend
EnvironmentFile=/var/www/high-risk-pregnancy-detection/backend/.env
ExecStart=/var/www/high-risk-pregnancy-detection/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target